  "done_markers": [
    "runpod-execution/status.json reports ok true",
    "runpod-execution/artifacts/validation/contract-self-check.json reports ok true",
    "runpod-execution/artifacts/candidate_ranking_top32.json exists with at most 32 candidates"
  ],
  "claim_levels_allowed": ["candidate", "insufficient_evidence", "blocked"],
  "default_claim_level": "candidate",
  "license_gates_required": [
    "Genie 3 dependency and weight terms review",
    "Boltz license review (MIT)",
    "ColabFold MSA service public-target-only posture"
  ],
  "no_false_success_notes": [
    "status.json ok true requires no failed stages and contract_self_check ok true.",
    "candidate_ranking_top32.json is a ranking artifact, not a binding claim.",
    "Any skipped or failed upstream stage must downgrade to partial, failed, blocked, or insufficient_evidence."
  ]
