      "timeout_minutes": 5,
      "checkpoint_marker": "validation/runtime_gate.json",
      "done_marker": "validation/runtime_gate.json",
      "resume_command": "python3 scripts/structure_factory/pd_l1_binder_hunt.py --stage runtime_gate --out runpod-execution/artifacts --json",
      "fail_closed": true
