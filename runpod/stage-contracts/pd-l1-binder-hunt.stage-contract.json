      "stage_contract_sha256_change",
      "target_window_sha256_change",
      "genie3_pinned_commit_sha_change",
      "genie3_hf_revision_change",
      "boltz_pinned_release_change",
      "repo_commit_change"
    ]
  },
  "stages": [
