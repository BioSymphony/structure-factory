      "stage_id": "target_intake",
      "description": "Materialize and hash the committed PD-L1 target-window report plus public target slice metadata.",
      "required": true,
      "expected_outputs": ["validation/target_intake.json"],
      "timeout_minutes": 5,
      "checkpoint_marker": "validation/target_intake.json",
      "done_marker": "validation/target_intake.json",
      "resume_command": "python3 scripts/structure_factory/pd_l1_binder_hunt.py --stage target_intake --out runpod-execution/artifacts --json",
