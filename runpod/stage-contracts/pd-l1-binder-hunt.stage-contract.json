      "timeout_minutes": 10,
      "checkpoint_marker": "validation/contract-self-check.json",
      "done_marker": "validation/contract-self-check.json",
      "resume_command": "python3 scripts/structure_factory/pd_l1_binder_hunt.py --stage contract_self_check --out runpod-execution/artifacts --json",
