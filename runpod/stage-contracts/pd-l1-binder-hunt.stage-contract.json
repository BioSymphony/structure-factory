{
  "schema_version": 1,
  "contract_id": "pd-l1-binder-hunt.stage-contract.v1",
  "manifest_id": "structure-factory-pd-l1-binder-hunt",
  "run_id": "structure-factory-pd-l1-binder-hunt-${STRUCTURE_FACTORY_RUN_ID}",
  "run_id_resolution_policy": "Campaign-level template. The bridge manifest supplies the concrete run_id through STRUCTURE_FACTORY_RUN_ID.",
  "campaign_id": "pd-l1-pd1-binder-design",
  "wave": "pd-l1-binder-hunt",
  "execution_profile": "genie3-boltz-design-ranking",
  "progress_ledger": "/workspace/runpod-execution/artifacts/stage-progress.jsonl",
  "success_claim": "Genie 3-generated PD-L1 binder candidates against public 4ZQK are Boltz cofolded, ranked in candidate_ranking.json and candidate_ranking_top32.json, and capped at candidate-level computational evidence.",
