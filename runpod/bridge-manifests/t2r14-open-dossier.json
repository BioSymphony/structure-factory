    },
    "gpuCount": 0,
    "gpuTypeIds": [],
    "imageDigestRequiredForReal": true,
    "imageName": "python:3.12-slim",
    "name": "bsf-demo-t2r14-open-dossier",
    "networkVolumeId": "",
