    "record_cost_estimate": true,
    "record_runtime_minutes": true,
    "retain_pod": false,
    "stop_or_delete_pod": true
  },
  "compute_profile": "gpu-secure-rfdiffusion-production-under-5h",
  "expected_artifacts": [
    {
