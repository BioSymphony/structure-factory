  "artifact_egress": {
    "archive_path": "runpod-execution/artifacts/runpod-execution.tar.gz",
    "mode": "workspace_archive",
    "requires_network_volume": true,
    "requires_object_store_upload": false,
    "requires_scp": false
  },
  "budget": {
    "max_estimated_cost_usd": 0,
    "max_runtime_minutes": 180,
    "terminate_after_minutes": 210
  },
  "campaign_id": "pd-l1-pd1-binder-design",
  "campaign_manifest_ref": "campaigns/pd-l1-pd1-binder-design/",
  "closeout": {
    "delete_pod_if_network_volume_attached": false,
    "linear_outcome_required": true,
    "prefer_billing_api_cost": true,
    "record_artifact_hashes": true,
    "record_cost_estimate": true,
    "record_runtime_minutes": true,
    "retain_pod": false,
    "stop_or_delete_pod": true
  },
  "compute_profile": "gpu-boltz-cofold-jury-under-3h",
  "expected_artifacts": [
    {
      "artifact_id": "status",
      "path": "runpod-execution/status.json",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "boltz_crosscheck_extended",
      "path": "runpod-execution/artifacts/validation/boltz_crosscheck_extended.json",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "jury_synthesis",
      "path": "runpod-execution/artifacts/validation/jury_synthesis.json",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "report_html",
      "path": "runpod-execution/artifacts/report/index.html",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "contract_self_check",
      "path": "runpod-execution/artifacts/validation/contract-self-check.json",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "stage_progress",
      "path": "runpod-execution/artifacts/stage-progress.jsonl",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "executed_commands",
      "path": "runpod-execution/artifacts/executed-commands.jsonl",
      "required": true,
      "sha256_required": true
    },
    {
      "artifact_id": "artifact_archive",
      "path": "runpod-execution/artifacts/runpod-execution.tar.gz",
      "required": true,
      "sha256_required": true
    }
  ],
  "launch_authorization": {
    "approved_at": "PENDING",
    "approved_by": "PENDING-OPERATOR-GATE",
    "linear_issue_url": "PENDING-TRACKER-ISSUE",
    "scope": "Public template only. This file documents the expected RunPod bridge-manifest shape. It is not execution-ready until a human/operator gate records current license/use context, budget, placement, a pushed public-safe commit SHA, provider credentials by reference, and cleanup policy.",
    "source": "templates/operator-wave-runbook.md"
  },
  "launch_manifest_ref": "runpod/bridge-manifests/pd-l1-downstream.json",
  "license_gates": [
    "Boltz license review (MIT)",
    "ColabFold MSA service public-target-only posture confirmed in operator_closeout"
  ],
  "manifest_kind": "symphony_runpod_launch",
  "monitoring": {
    "max_silent_minutes": 15,
    "poll_interval_seconds": 30,
    "record_pod_fields": [
      "id",
      "desiredStatus",
      "lastStartedAt",
      "lastStatusChange",
      "costPerHr",
      "adjustedCostPerHr",
      "machine.dataCenterId",
      "portMappings"
    ],
    "required_signals": [
      "provider_actual_status",
      "runtime_uptime_seconds",
      "image_pull_success_or_failure",
      "stage_progress_heartbeat"
    ],
    "requires_log_artifact": true,
    "requires_status_file": true,
    "requires_workload_heartbeat": true
  },
  "provider": {
    "adapter": "runpod_pod_v1",
    "name": "runpod"
  },
  "public_template_note": "Public template only. This file documents the expected RunPod bridge-manifest shape. It is not execution-ready until a human/operator gate records current license/use context, budget, placement, a pushed public-safe commit SHA, provider credentials by reference, and cleanup policy.",
  "public_template_status": "non_launchable_public_template",
  "remote_launch_allowed": false,
  "repo": {
    "commit_or_snapshot": "0000000000000000000000000000000000000000",
    "commit_or_snapshot_pin_policy": "Replace with a pushed, public-safe 40-character commit SHA before any real launch. Source-ready checks must verify the commit is fetchable from repo.url_or_path.",
    "source": "git_remote_or_snapshot",
    "url_or_path": "https://github.com/BioSymphony/biosymphony-structure-factory-public.git",
    "workdir": "/workspace/biosymphony-structure-factory"
  },
  "run_id": "structure-factory-pd-l1-downstream-cofold",
  "runpod": {
    "cloudType": "SECURE",
    "computeType": "GPU",
    "containerDiskInGb": 80,
    "dataCenterIds": [],
    "env": {
      "BOLTZ_CACHE": "/workspace/software/weights/boltz",
      "STRUCTURE_FACTORY_ARTIFACT_ROOT": "/workspace/runpod-execution/artifacts",
      "STRUCTURE_FACTORY_BOLTZ_WEIGHTS_DIR": "/workspace/software/weights/boltz",
      "STRUCTURE_FACTORY_CAMPAIGN_ID": "pd-l1-pd1-binder-design",
      "STRUCTURE_FACTORY_EXECUTION_PROFILE": "pd-l1-downstream-cofold-jury",
      "STRUCTURE_FACTORY_GIT_REF": "PENDING-PUBLIC-SHA",
      "STRUCTURE_FACTORY_MVD_ROOT": "/workspace/runpod-execution/mvd",
      "STRUCTURE_FACTORY_REPO_ROOT": "/workspace/biosymphony-structure-factory",
      "STRUCTURE_FACTORY_REPO_SOURCE": "network_volume",
      "STRUCTURE_FACTORY_REPO_URL": "https://github.com/BioSymphony/biosymphony-structure-factory-public.git",
      "STRUCTURE_FACTORY_RUN_ID": "structure-factory-pd-l1-downstream-cofold",
      "STRUCTURE_FACTORY_SOFTWARE_ROOT": "/workspace/software",
      "STRUCTURE_FACTORY_STAGE_CONTRACT": "runpod/stage-contracts/pd-l1-downstream.stage-contract.json",
      "STRUCTURE_FACTORY_TERMINAL_STATE": "complete_tiny_tranche",
      "STRUCTURE_FACTORY_VOLUME_ROOT": "/workspace/structure-factory"
    },
    "gpuCount": 1,
    "gpuTypeIds": [
      "NVIDIA GeForce RTX 4090",
      "NVIDIA L40S",
      "NVIDIA L40",
      "NVIDIA RTX A6000",
      "NVIDIA RTX 6000 Ada Generation",
      "NVIDIA A40",
      "NVIDIA A100 80GB PCIe",
      "NVIDIA H100 PCIe",
      "NVIDIA H100 80GB HBM3"
    ],
    "imageDigestRequiredForReal": true,
    "imageName": "pytorch/pytorch:2.4.0-cuda12.4-cudnn9-runtime",
    "image_capabilities": [
      "git"
    ],
    "name": "structure-factory-pd-l1-downstream-cofold",
    "networkVolumeId": "STRUCTURE_FACTORY_RUNPOD_NETWORK_VOLUME_ID",
    "ports": [
      "8888/http",
      "8000/http"
    ],
    "registryAuth": {
      "policy_note": "no_auth_for_public_image",
      "provider": "dockerhub",
      "required": false
    },
    "templateId": "",
    "toolSetup": {
      "default_recommended": "network_volume_bootstrap",
      "network_volume_id": "STRUCTURE_FACTORY_RUNPOD_NETWORK_VOLUME_ID",
      "policy_note": "Public template. Runtime tool setup must be performed by the operator after current-term review; no license-gated binaries, private installers, weights, or prior-run artifacts are stored in git.",
      "software_root": "/workspace/software",
      "supported_postures": [
        "network_volume_bootstrap"
      ],
      "weights_root": "/workspace/software/weights"
    },
    "volumeInGb": 100,
    "volumeMountPath": "/workspace"
  },
  "safety": {
    "license_policy": "Boltz (MIT) only; no AlphaFold 3",
    "no_literal_secrets": true,
    "private_data_policy": "public data only: PD-L1 sequence from UniProt Q9NZQ7 (19-127); ColabFold MSA service is permitted only because the target is public",
    "public_template_policy": "No secrets, concrete provider resources, private volume assumptions, prior-run artifacts, or accepted-license state are encoded in this public manifest."
  },
  "schema_version": 1,
  "shard": {
    "generated_candidates_dir": "/workspace/runpod-execution/artifacts/design_candidates/",
    "target_label": "PD-L1",
    "wave": "downstream"
  },
  "stage_contract_ref": "runpod/stage-contracts/pd-l1-downstream.stage-contract.json",
  "startup": {
    "commands": [
      "set -euo pipefail",
      "echo 'Public non-launchable template. Rebuild a private/operator-gated launch packet from tracked source before execution.'",
      "exit 64"
    ],
    "heartbeat_file": "runpod-execution/monitor_events.ndjson",
    "inspection": {
      "hold_after_success_seconds": 0,
      "http_artifact_server_port": null
    },
    "log_file": "runpod-execution/logs/startup.log",
    "mode": "dockerStartCmd",
    "progress": {
      "http_status_server_port": 8888,
      "include_log_tail": false,
      "log_tail_bytes": 4096
    },
    "status_file": "runpod-execution/status.json"
  },
  "validation_commands": [
    "make public-switch-check",
    "PYTHONPATH=src python3 -m biosymphony_structure_factory.cli audit ."
  ],
  "wave": "downstream",
  "worker_coordination": {
    "linear_issue_lock_required": true,
    "read_only_monitors_allowed": true,
    "resource_name_prefix": "structure-factory-pd-l1-downstream-cofold",
    "single_mutating_worker": true
  },
  "workload": {
    "checkpoint_policy": {
      "mode": "stage-progress-jsonl"
    },
    "description": "Public non-launchable bridge template. Rebuild from source, pin a public-safe commit, and satisfy operator/provider/license gates before paid execution.",
    "scale": "small",
    "shards": [
      {
        "shard_id": "pd-l1-downstream-cofold-shard-1"
      }
    ],
    "stage_contract": {
      "claim_level": "candidate",
      "done_markers": [
        "runpod-execution/status.json reports ok true",
        "runpod-execution/artifacts/validation/contract-self-check.json reports ok true",
        "runpod-execution/artifacts/validation/boltz_crosscheck_extended.json exists and is non-empty",
        "runpod-execution/artifacts/report/index.html exists and is non-empty",
        "runpod-execution/artifacts/runpod-execution.tar.gz exists"
      ],
      "exact_commands": [
        "bash runpod/entrypoints/pd-l1-downstream.sh"
      ],
      "expected_outputs": [
        "runpod-execution/status.json",
        "runpod-execution/artifacts/validation/boltz_crosscheck_extended.json",
        "runpod-execution/artifacts/validation/jury_synthesis.json",
        "runpod-execution/artifacts/candidate_jury.json",
        "runpod-execution/artifacts/report/index.html",
        "runpod-execution/artifacts/claim_ledger.json",
        "runpod-execution/artifacts/operator_closeout.md",
        "runpod-execution/artifacts/validation/contract-self-check.json",
        "runpod-execution/artifacts/stage-progress.jsonl",
        "runpod-execution/artifacts/executed-commands.jsonl",
        "runpod-execution/artifacts/runpod-execution.tar.gz"
      ],
      "fail_closed": true,
      "inputs": [
        "Operator-gated runtime design_candidates/ manifest set with backbone structures outside git",
        "Operator-gated runtime target_window_dossier.json for the public PD-L1 target window",
        "Boltz weights and environment prepared through a reviewed runtime setup posture",
        "Pinned public-safe repo SHA containing reconstruct_gen_info_from_disk"
      ],
      "resume_policy": "Each runner stage is invokable individually via the entrypoint's per-stage python3 calls; partial-summary is written on failure. Mid-run pod restart should rerun the entrypoint; completed stages are detected via their checkpoint_marker JSON files on the NV.",
      "route_proof": {
        "artifact_validation": [
          "validation_commands check status.json + contract-self-check.json both report ok true",
          "expected_artifacts include boltz_crosscheck_extended.json, jury_synthesis.json, report/index.html, contract-self-check.json, stage-progress.jsonl, executed-commands.jsonl, and the artifact_archive"
        ],
        "claim_boundaries": [
          "claim_level cap is candidate; positive evidence is Boltz iPTM-only and does not constitute experimental validation",
          "operator_closeout.md MUST set one of the campaign's terminal_state values",
          "no AlphaFold 3, no licensed prediction tools; Boltz weights are the public huggingface release"
        ],
        "input_materialization": [
          "validation/downstream-preflight.json records the on-disk candidate count and which structures resolved before any boltz call",
          "validation/boltz_runtime_check.json records the boltz CLI path and weight cache state",
          "runner's reconstruct_gen_info_from_disk persists the rebuilt validation/genie3_generation_extended.json on first call so downstream stages have it"
        ],
        "tool_invocation": [
          "bash runpod/entrypoints/pd-l1-downstream.sh",
          "executed-commands.jsonl records the exact runner --stage <id> invocation and exit code for each of the five tail stages"
        ]
      },
      "timeout_minutes": 180
    }
  }
}
