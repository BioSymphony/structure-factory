{
  "schema_version": 1,
  "manifest_type": "screening_manifest",
  "campaign_id": "screening-superpowers",
  "run_id": "screening-superpowers-fixture",
  "intent": {
    "mode": "screen",
    "natural_language_goal": "Run an OpenBind-style no-download screening fixture with simple baselines, docking proxies, and selective dossiers.",
    "target_hint": "fixture protease pocket",
