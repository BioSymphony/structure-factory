{
  "schema_version": 1,
  "module_type": "schema_contract",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "modules/schemas/active-learning-tranches.v1.schema.json",
  "title": "Structure Factory active learning tranches v1",
  "type": "object",
  "required": ["schema_version", "campaign_id", "source_artifacts", "tranches"],
  "properties": {
    "schema_version": { "const": 1 },
    "campaign_id": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "tranches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tranche_id", "selection_mode", "ligand_ids", "rationale", "budget_fraction"],
        "properties": {
          "tranche_id": { "type": "string", "minLength": 1 },
          "selection_mode": { "enum": ["top_ranked", "control", "method_disagreement", "uncertainty", "scaffold_diversity", "rescue", "design_followup"] },
          "ligand_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "rationale": { "type": "string", "minLength": 1 },
          "budget_fraction": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
