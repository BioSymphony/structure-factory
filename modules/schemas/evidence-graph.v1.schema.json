{
  "schema_version": 1,
  "module_type": "schema_contract",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "modules/schemas/evidence-graph.v1.schema.json",
  "title": "Structure Factory evidence graph v1",
  "type": "object",
  "required": ["schema_version", "graph_id", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": 1 },
    "graph_id": { "type": "string", "minLength": 1 },
    "nodes": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "edges": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
