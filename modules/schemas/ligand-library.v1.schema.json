{
  "schema_version": 1,
  "module_type": "schema_contract",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "modules/schemas/ligand-library.v1.schema.json",
  "title": "Structure Factory ligand library v1",
  "type": "object",
  "required": [
    "schema_version",
    "library_id",
    "ligands"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "library_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string"
    },
    "protonation_policy": {
      "type": "string"
    },
    "stereochemistry_policy": {
      "type": "string"
    },
    "ligands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ligand_id",
          "smiles"
        ],
        "properties": {
          "ligand_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "smiles": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string"
          },
          "known_class": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
