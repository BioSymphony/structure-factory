{
  "schema_version": 1,
  "module_type": "schema_contract",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "modules/schemas/benchmark-set.v1.schema.json",
  "title": "Structure Factory benchmark set v1",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark_id",
    "sources",
    "scope",
    "splits",
    "controls",
    "metrics",
    "claim_ceiling"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "benchmark_id": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "kind", "url", "terms_posture"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["openbind", "plinder", "posebench", "posex", "repo_fixture", "other_public"] },
          "url": { "type": "string", "minLength": 1 },
          "terms_posture": { "enum": ["public_metadata_only", "terms_review_required", "runtime_gated"] }
        },
        "additionalProperties": true
      }
    },
    "scope": {
      "type": "object",
      "required": ["target_ids", "task_types", "public_only"],
      "properties": {
        "target_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "task_types": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["redocking", "cross_docking", "cofolding", "affinity_ranking", "screening_enrichment"] }
        },
        "public_only": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "splits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["split_id", "role", "leakage_guard"],
        "properties": {
          "split_id": { "type": "string", "minLength": 1 },
          "role": { "enum": ["fixture", "calibration", "validation", "holdout"] },
          "leakage_guard": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "controls": {
      "type": "object",
      "required": ["positive", "negative"],
      "properties": {
        "positive": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "negative": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["metric_id", "task", "direction"],
        "properties": {
          "metric_id": { "type": "string", "minLength": 1 },
          "task": { "type": "string", "minLength": 1 },
          "direction": { "enum": ["higher_is_better", "lower_is_better", "target_range"] }
        },
        "additionalProperties": true
      }
    },
    "claim_ceiling": { "enum": ["candidate", "calibrated", "validated"] }
  },
  "additionalProperties": true
}
