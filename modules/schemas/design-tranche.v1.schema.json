{
  "schema_version": 1,
  "module_type": "schema_contract",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "modules/schemas/design-tranche.v1.schema.json",
  "title": "Structure Factory design tranche v1",
  "type": "object",
  "required": ["schema_version", "tranche_id", "method_adapters", "source_scaffold", "designs", "claim_ceiling"],
  "properties": {
    "schema_version": { "const": 1 },
    "tranche_id": { "type": "string", "minLength": 1 },
    "method_adapters": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "source_scaffold": { "type": "object" },
    "designs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["design_id", "sequence", "provenance", "scores"],
        "properties": {
          "design_id": { "type": "string", "minLength": 1 },
          "sequence": { "type": "string", "minLength": 1 },
          "provenance": { "type": "object" },
          "scores": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "claim_ceiling": { "enum": ["candidate", "calibrated", "validated"] }
  },
  "additionalProperties": true
}
