{
  "schema_version": 1,
  "module_type": "provider_profile",
  "provider": "runpod",
  "provider_class": "pod",
  "profile_id": "runpod-pod-map-model-report",
  "maps_campaign_profile": "map_model_report",
  "blessed_path": true,
  "workspace_root": "/workspace/structure-factory",
  "artifact_root": "/workspace/structure-factory/runs/<run-id>",
  "secret_mode": "runpod_runtime_secrets",
  "operator_gate_required": true,
  "volume_mount": "/workspace",
  "network_volume_required": false,
  "scratch_only": true,
  "recommended_gpu": "NVIDIA RTX 4090",
  "fallback_gpu": "NVIDIA L40S",
  "gpu_count": 1,
  "container_disk_gb": 160,
  "image_map": {
    "model-build": "docker.io/library/ubuntu:22.04"
  },
  "execution_ready_requires": [
    "public_or_operator_image_digest",
    "pinned_git_ref",
    "explicit_operator_launch",
    "input_audit",
    "contract_self_check",
    "map_model_download_authorization"
  ]
}
