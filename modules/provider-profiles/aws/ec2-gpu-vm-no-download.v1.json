{
  "schema_version": 1,
  "module_type": "provider_profile",
  "provider": "aws",
  "provider_class": "cloud_vm",
  "profile_id": "aws-ec2-gpu-vm-no-download",
  "maps_campaign_profile": "screening_no_download_smoke",
  "blessed_path": false,
  "workspace_root": "/workspace/structure-factory",
  "artifact_root": "s3://STRUCTURE_FACTORY_AWS_ARTIFACT_BUCKET/runs/<run-id>",
  "secret_mode": "iam_role_and_runtime_environment",
  "operator_gate_required": true,
  "recommended_gpu": "L40S/A10G/A100-class EC2 GPU debug instance",
  "gpu_required": true,
  "mock_gpu_allowed": false,
  "raw_downloads_allowed": false,
  "image_strategy": "ecr_digest_or_bootstrap_script",
  "aws": {
    "service": "ec2",
    "instance_profile_ref": "STRUCTURE_FACTORY_AWS_INSTANCE_PROFILE",
    "security_group_ref": "STRUCTURE_FACTORY_AWS_SECURITY_GROUP",
    "subnet_ref": "STRUCTURE_FACTORY_AWS_SUBNET",
    "artifact_bucket_ref": "STRUCTURE_FACTORY_AWS_ARTIFACT_BUCKET",
    "log_group_ref": "STRUCTURE_FACTORY_AWS_CLOUDWATCH_LOG_GROUP",
    "budget_name_ref": "STRUCTURE_FACTORY_AWS_BUDGET_NAME",
    "artifact_egress": "s3_checksum_required",
    "cleanup_policy": "terminate_instance_unless_explicit_retention"
  },
  "execution_ready_requires": [
    "aws_account_region_allowlist",
    "ec2_gpu_quota_check",
    "instance_profile",
    "network_security_review",
    "s3_artifact_bucket",
    "cloudwatch_log_group",
    "aws_budget_alert",
    "pinned_git_ref",
    "digest_pinned_image_or_bootstrap",
    "input_audit",
    "contract_self_check",
    "explicit_operator_launch"
  ],
  "notes": "AWS EC2 rescue/debug path. AWS Batch remains the reviewed AWS scale path."
}
